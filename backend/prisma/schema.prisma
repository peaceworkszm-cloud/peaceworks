generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model User {
  id                     Int       @id @default(autoincrement())
  username               String
  firstName              String?
  lastName               String?
  middleName             String?
  jobTitle               String?
  email                  String    @unique


  password               String
  phoneNumber            String    @unique
  token                  String?
  role                   String  @default("STAFF")
  group                  Int?
  nrc_card_id            String
  bloodGroup             String?
  address                String?
  dateOfBirth            DateTime?
  gender                 String?
  emergencyContact       String?
  profilePicture         String?
  bio                    String?
  location               String?
  isEmailVerified        Boolean   @default(false)
  emailVerificationToken String?
  blocked                Boolean   @default(false)
  createdAt              DateTime  @default(now())

  reviewsReceived        Task[]    @relation("TaskReviewFor")
}

model Task {
  id              Int      @id @default(autoincrement())
  publicId        String?  @unique
  title           String
  category        String
  status          String   @default("Open")
  statusTone      String?
  location        String
  date            String
  time            String?
  startTime       String?
  endTime         String?
  offerPrice      String
  unitDef         String
  estEarning      String?
  shortDesc       String
  employerName    String
  employerId      String
  employerUserId  String
  verified        Boolean  @default(true)
  imageUrl        String?
  acceptedById    String?
  acceptedByName  String?
  acceptedByEmail String?
  acceptedByPhone String?
  acceptedTimestamp String?
  reviewRating    Int?
  reviewComment   String?
  reviewBy        String?
  reviewForId     Int?
  reviewFor       User?    @relation("TaskReviewFor", fields: [reviewForId], references: [id])
  reviewGiven     Boolean  @default(false)
  reviewAt        DateTime?
  createdAt       DateTime @default(now())
}
